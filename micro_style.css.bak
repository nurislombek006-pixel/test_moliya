}

body.dark-theme .app-menu-overlay,
body.dark-theme .history-modal,
body.dark-theme .agreement-overlay {
    background: rgba(2, 6, 23, 0.72) !important;
}

body.dark-theme .app-drawer-close,
body.dark-theme .app-drawer-icon-button,
body.dark-theme .app-menu-toggle,
body.dark-theme .app-favorites-toggle,
body.dark-theme .premium-incognito-toggle {
    background: rgba(15, 23, 42, 0.9) !important;
    color: #e5e7eb !important;
    box-shadow: 0 14px 28px rgba(2, 6, 23, 0.5) !important;
}

body.dark-theme .app-menu-toggle span {
    background: #f8fafc !important;
}

body.dark-theme .app-menu-item-badge,
body.dark-theme button.main,
body.dark-theme .top-finish-btn {
    background: linear-gradient(135deg, #4338ca 0%, #7c3aed 100%) !important;
    color: #ffffff !important;
}

body.dark-theme .favorite-question-btn,
body.dark-theme .study-favorite-btn {
    background: rgba(30, 41, 59, 0.95) !important;
    color: #f8fafc !important;
    border-color: rgba(129, 140, 248, 0.26) !important;
}

body.dark-theme .favorite-question-btn.is-active,
body.dark-theme .study-favorite-btn.is-active,
body.dark-theme .app-favorites-toggle.is-active,
body.dark-theme .app-favorites-toggle:hover {
    background: linear-gradient(135deg, #78350f 0%, #b45309 100%) !important;
    color: #fef3c7 !important;
    border-color: rgba(251, 191, 36, 0.45) !important;
}


body.dark-theme .history-meta span {
    background: rgba(30, 41, 59, 0.98) !important;
    color: #f8fafc !important;
    border: 1px solid rgba(148, 163, 184, 0.22) !important;
}

body.dark-theme .history-empty,
body.dark-theme .cheat-log,
body.dark-theme .cheat-log.clean,
body.dark-theme .history-details {
    background: rgba(15, 23, 42, 0.96) !important;
    color: #e5e7eb !important;
    border-color: rgba(148, 163, 184, 0.18) !important;
}

body.dark-theme .history-actions button {
    box-shadow: 0 10px 20px rgba(2, 6, 23, 0.35) !important;
}

body.dark-theme .stats-hero-subtitle,
body.dark-theme .stats-pill {
    color: #eef2ff !important;
}

body.dark-theme .stats-highlight-card,
body.dark-theme .stats-highlight-card--success,
body.dark-theme .stats-highlight-card--warm,
body.dark-theme .stats-highlight-card--violet,
body.dark-theme .stats-highlight-card--calm,
body.dark-theme .stats-highlight-card--speed {
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.98), rgba(17, 24, 39, 0.98)) !important;
    border-color: rgba(129, 140, 248, 0.2) !important;
    box-shadow: 0 18px 30px rgba(2, 6, 23, 0.28), inset 0 1px 0 rgba(255,255,255,0.03) !important;
}

body.dark-theme .stats-highlight-card--dark {
    background: linear-gradient(135deg, #0f172a 0%, #111827 100%) !important;
    border-color: rgba(129, 140, 248, 0.18) !important;
}

body.dark-theme .stats-highlight-label,
body.dark-theme .stats-highlight-value,
body.dark-theme .stats-highlight-note,
body.dark-theme .stats-section-title,
body.dark-theme .stats-hero-title,
body.dark-theme .stats-hero-score,
body.dark-theme .stats-metric-label,
body.dark-theme .stats-metric-value,
body.dark-theme .stats-metric-note {
    color: #f8fafc !important;
}

body.dark-theme .stats-highlight-label,
body.dark-theme .stats-metric-label,
body.dark-theme .stats-hero-title {
    opacity: 0.88;
}

body.dark-theme .stats-highlight-note,
body.dark-theme .stats-metric-note {
    color: #cbd5e1 !important;
}

body.dark-theme .stats-section,
body.dark-theme .stats-section-speed,
body.dark-theme .stats-metric-item {
    background: linear-gradient(180deg, rgba(10, 18, 38, 0.96), rgba(15, 23, 42, 0.99)) !important;
    border-color: rgba(129, 140, 248, 0.18) !important;
}

/* ===== SUBSCRIPTION PURCHASE MODAL ===== */
.subscription-menu-link {
    position: relative;
    overflow: hidden;
}

.subscription-menu-link::before {
    content: "👑";
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    margin-right: 8px;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.12);
    vertical-align: -2px;
}

.subscription-panel {
    position: relative;
    width: min(720px, 100%);
}

.subscription-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 42px;
    height: 42px;
    border: 1px solid rgba(148, 163, 184, 0.3);
    border-radius: 14px;
    background: rgba(248, 250, 252, 0.92);
    color: #111827;
    font-size: 28px;
    line-height: 1;
    cursor: pointer;
}


.subscription-free-period {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin: 14px 0;
    padding: 12px 14px;
    border-radius: 18px;
    border: 1px solid rgba(99, 102, 241, 0.24);
    background: linear-gradient(135deg, #eef2ff, #f5f3ff);
    color: #312e81;
    font-weight: 850;
}

.subscription-free-period strong {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 86px;
    padding: 8px 12px;
    border-radius: 999px;
    background: #ffffff;
    color: #4c1d95;
    box-shadow: 0 8px 18px rgba(79, 70, 229, 0.12);
}

.subscription-plans {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin: 14px 0;
}

.subscription-plan-card {
    border: 1px solid rgba(99, 102, 241, 0.18);
    border-radius: 18px;
    padding: 14px;
    background: linear-gradient(180deg, #f8fafc, #eef2ff);
}

.subscription-plan-title {
    font-weight: 900;
    color: #312e81;
    margin-bottom: 6px;
}

.subscription-plan-desc {
    font-size: 13px;
    line-height: 1.45;
    color: #475569;
}

.subscription-plan-price-wrap {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    margin: 0 0 8px;
}

.subscription-plan-price {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    margin: 0;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(79, 70, 229, 0.12);
    color: #4c1d95;
    font-size: 14px;
    font-weight: 900;
    letter-spacing: 0.01em;
}

.subscription-plan-price-meta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
}

.subscription-plan-old-price {
    color: #64748b;
    font-size: 12px;
    font-weight: 700;
    text-decoration: line-through;
    text-decoration-thickness: 1.5px;
}

.subscription-plan-discount-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 24px;
    padding: 4px 8px;
    border-radius: 999px;
    background: rgba(79, 70, 229, 0.1);
    color: #4338ca;
    font-size: 12px;
    font-weight: 900;
}

.subscription-payment-card {
    margin: 14px 0;
    padding: 16px;
    border-radius: 20px;
    border: 1px solid rgba(99, 102, 241, 0.22);
    background: #0f172a;
    color: #f8fafc;
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.18);
}

.subscription-payment-label {
    font-size: 13px;
    color: #c7d2fe;
    margin-bottom: 8px;
    font-weight: 800;
}

.subscription-card-number {
    font-size: clamp(22px, 5vw, 34px);
    font-weight: 900;
    letter-spacing: 1.5px;
    line-height: 1.2;
    word-break: break-word;
}

.subscription-card-holder {
    margin-top: 8px;
    font-size: 14px;
    color: #cbd5e1;
}

.subscription-note {
    padding: 12px 14px;
    border-radius: 16px;
    background: #fff7ed;
    color: #7c2d12;
    border: 1px solid #fed7aa;
    line-height: 1.5;
    margin-bottom: 14px;
}

.subscription-actions .main {
    flex: 1 1 220px;
}

.subscription-status {
    margin-top: 12px;
    padding: 12px 14px;
    border-radius: 14px;
    font-weight: 700;
    line-height: 1.45;
}

.subscription-status.hidden {
    display: none;
}

.subscription-status.is-success {
    background: #dcfce7;
    color: #166534;
    border: 1px solid #86efac;
}

.subscription-status.is-error {
    background: #fee2e2;
    color: #991b1b;
    border: 1px solid #fecaca;
}


body.dark-theme .subscription-free-period {
    background: linear-gradient(135deg, rgba(49, 46, 129, 0.58), rgba(88, 28, 135, 0.46));
    color: #ddd6fe;
    border-color: rgba(167, 139, 250, 0.28);
}

body.dark-theme .subscription-free-period strong {
    background: rgba(15, 23, 42, 0.72);
    color: #f5f3ff;
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.18);
}

body.dark-theme .subscription-close {
    background: rgba(30, 41, 59, 0.92);
    color: #f8fafc;
    border-color: rgba(148, 163, 184, 0.24);
}

body.dark-theme .subscription-plan-card {
    background: rgba(30, 41, 59, 0.9);
    border-color: rgba(129, 140, 248, 0.26);
}

body.dark-theme .subscription-plan-title {
    color: #c4b5fd;
}

body.dark-theme .subscription-plan-price {
    background: rgba(129, 140, 248, 0.18);
    color: #ede9fe;
}

body.dark-theme .subscription-plan-old-price {
    color: #cbd5e1;
}

body.dark-theme .subscription-plan-discount-badge {
    background: rgba(129, 140, 248, 0.16);
    color: #ede9fe;
}

body.dark-theme .subscription-plan-desc {
    color: #cbd5e1;
}

body.dark-theme .subscription-note {
    background: rgba(120, 53, 15, 0.35);
    color: #fed7aa;
    border-color: rgba(251, 146, 60, 0.28);
}

body.dark-theme .subscription-status.is-success {
    background: rgba(20, 83, 45, 0.75);
    color: #dcfce7;
    border-color: rgba(74, 222, 128, 0.38);
}

body.dark-theme .subscription-status.is-error {
    background: rgba(127, 29, 29, 0.75);
    color: #fee2e2;
    border-color: rgba(248, 113, 113, 0.38);
}

@media (max-width: 640px) {
    .subscription-free-period {
        align-items: flex-start;
        flex-direction: column;
    }

    .subscription-free-period strong {
        width: 100%;
    }

    .subscription-plans {
        grid-template-columns: 1fr;
    }

    .subscription-panel {
        padding-top: 24px;
    }
}

/* ===== SUBSCRIPTION PURCHASE MODAL POLISH ===== */
.subscription-front-note {
    margin: -4px 0 14px;
    padding: 12px 14px;
    border-radius: 16px;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.16);
    color: #475569;
    font-size: 14px;
    line-height: 1.55;
}

.subscription-panel .agreement-title {
    margin-top: 10px;
    margin-bottom: 12px;
    line-height: 1.15;
}

.subscription-panel .agreement-lead {
    margin-bottom: 14px;
    color: #374151;
}

.subscription-payment-card {
    background: linear-gradient(135deg, #0f172a, #111827 62%, #312e81);
}

.subscription-note {
    background: linear-gradient(135deg, #f8fafc, #eef2ff);
    border-color: rgba(99, 102, 241, 0.16);
    color: #334155;
    font-weight: 650;
}

body.dark-theme .subscription-front-note {
    background: rgba(49, 46, 129, 0.34);
    border-color: rgba(129, 140, 248, 0.24);
    color: #cbd5e1;
}

body.dark-theme .subscription-panel .agreement-lead {
    color: #d1d5db;
}

body.dark-theme .subscription-note {
    background: rgba(30, 41, 59, 0.82);
    border-color: rgba(129, 140, 248, 0.24);
    color: #e5e7eb;
}

@media (max-width: 640px) {
    .subscription-panel {
        width: min(100%, 94vw);
        padding: 22px 20px 20px;
        border-radius: 26px;
    }

    .subscription-panel .agreement-title {
        font-size: clamp(26px, 8vw, 34px);
        padding-right: 44px;
    }

    .subscription-panel .agreement-lead {
        font-size: 15px;
        line-height: 1.55;
    }

    .subscription-front-note {
        font-size: 13px;
    }

    .subscription-payment-card {
        padding: 16px 14px;
    }

    .subscription-card-number {
        font-size: clamp(21px, 7vw, 30px);
        letter-spacing: 1px;
    }
}


/* ===== SUBSCRIPTION PURCHASE MODAL FINAL CLEANUP ===== */
.subscription-panel {
    max-height: calc(100vh - 34px);
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    border: 1px solid rgba(99, 102, 241, 0.16);
}

.subscription-panel .agreement-title {
    text-align: left;
    padding-right: 52px;
    font-size: clamp(26px, 5.8vw, 34px);
}

.subscription-panel .agreement-lead {
    padding: 12px 14px;
    border-radius: 18px;
    background: rgba(99, 102, 241, 0.07);
    border: 1px solid rgba(99, 102, 241, 0.16);
    font-size: 15px;
    line-height: 1.55;
}

.subscription-plans {
    gap: 8px;
}

.subscription-plan-card {
    box-shadow: 0 10px 22px rgba(15, 23, 42, 0.06);
}

.subscription-payment-card {
    margin-top: 12px;
}

.subscription-note {
    text-align: center;
    font-size: 14px;
}

body.dark-theme .subscription-panel {
    background: linear-gradient(180deg, rgba(10, 18, 38, 0.98), rgba(15, 23, 42, 0.99)) !important;
}

body.dark-theme .subscription-panel .agreement-lead {
    background: rgba(49, 46, 129, 0.34);
    border-color: rgba(129, 140, 248, 0.24);
    color: #e5e7eb;
}

@media (max-width: 640px) {
    .subscription-overlay {
        padding: 14px;
    }

    .subscription-panel {
        width: min(100%, 96vw);
        padding: 20px 18px 18px;
        border-radius: 24px;
    }

    .subscription-close {
        top: 12px;
        right: 12px;
        width: 40px;
        height: 40px;
    }

    .subscription-panel .agreement-title {
        font-size: clamp(24px, 7vw, 31px);
        line-height: 1.18;
    }

    .subscription-panel .agreement-lead {
        font-size: 14px;
    }

    .subscription-card-number {
        font-size: clamp(22px, 7vw, 29px);
        letter-spacing: 0.9px;
    }
}


/* ===== SUBSCRIPTION MODAL MOBILE FIT FIX ===== */
.subscription-overlay {
    align-items: flex-start !important;
    justify-content: center !important;
    overflow-y: auto !important;
    -webkit-overflow-scrolling: touch;
    padding: 12px 10px 20px !important;
}

.subscription-panel {
    width: min(680px, calc(100vw - 20px)) !important;
    max-height: none !important;
    overflow: visible !important;
    margin: 0 auto 18px !important;
    padding: 18px 16px 16px !important;
    border-radius: 22px !important;
}

.subscription-close {
    position: sticky !important;
    top: 8px !important;
    z-index: 8 !important;
    float: right;
    margin: -4px -4px 4px 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    box-shadow: 0 12px 26px rgba(15, 23, 42, 0.16);
}

.subscription-panel .agreement-badge {
    margin-top: 0;
    margin-bottom: 8px;
}

.subscription-panel .agreement-title {
    clear: none;
    margin: 6px 0 10px !important;
    padding-right: 48px !important;
    font-size: clamp(23px, 6vw, 30px) !important;
    line-height: 1.14 !important;
}

.subscription-panel .agreement-lead {
    margin: 0 0 10px !important;
    padding: 10px 12px !important;
    border-radius: 16px !important;
    font-size: 14px !important;
    line-height: 1.45 !important;
}

.subscription-plans {
    gap: 8px !important;
    margin: 10px 0 !important;
}

.subscription-plan-card {
    padding: 11px 12px !important;
    border-radius: 16px !important;
}

.subscription-plan-title {
    margin-bottom: 5px !important;
    font-size: 16px !important;
}

.subscription-plan-price-wrap {
    gap: 5px !important;
    margin-bottom: 6px !important;
}

.subscription-plan-price {
    margin: 0 !important;
    padding: 5px 10px !important;
    font-size: 13px !important;
}

.subscription-plan-price-meta {
    gap: 5px !important;
}

.subscription-plan-old-price,
.subscription-plan-discount-badge {
    font-size: 11px !important;
}

.subscription-plan-desc {
    font-size: 13px !important;
    line-height: 1.35 !important;
}

.subscription-payment-card {
    margin: 10px 0 !important;
    padding: 13px 14px !important;
    border-radius: 18px !important;
}

.subscription-payment-label {
    margin-bottom: 6px !important;
}

.subscription-card-number {
    font-size: clamp(23px, 6vw, 32px) !important;
    letter-spacing: 1px !important;
}

.subscription-card-holder {
    margin-top: 6px !important;
    font-size: 13px !important;
}

.subscription-note {
    margin: 10px 0 10px !important;
    padding: 10px 12px !important;
    border-radius: 15px !important;
    font-size: 13px !important;
    line-height: 1.42 !important;
    text-align: left !important;
}

.subscription-actions {
    gap: 8px !important;
}

.subscription-actions .main {
    min-height: 44px !important;
    padding: 11px 12px !important;
    border-radius: 15px !important;
    font-size: 14px !important;
}

.subscription-bottom-close {
    background: rgba(15, 23, 42, 0.06) !important;
    color: #334155 !important;
}

body.dark-theme .subscription-bottom-close {
    background: rgba(148, 163, 184, 0.12) !important;
    color: #e5e7eb !important;
}

@media (max-width: 640px) {
    .subscription-overlay {
        padding-top: 8px !important;
    }

    .subscription-panel {
        width: calc(100vw - 16px) !important;
        padding: 15px 14px 14px !important;
        border-radius: 20px !important;
    }

    .subscription-close {
        width: 44px !important;
        height: 44px !important;
        min-width: 44px !important;
        min-height: 44px !important;
        font-size: 28px !important;
    }

    .subscription-panel .agreement-title {
        font-size: clamp(22px, 6.3vw, 28px) !important;
        padding-right: 46px !important;
    }

    .subscription-plans {
        grid-template-columns: 1fr !important;
    }

    .subscription-plan-card {
        display: grid;
        grid-template-columns: 1fr auto;
        column-gap: 8px;
        align-items: center;
    }

    .subscription-plan-title {
        margin: 0 !important;
    }

    .subscription-plan-price-wrap {
        grid-column: 2;
        grid-row: 1;
        align-items: flex-end;
        margin: 0 !important;
    }

    .subscription-plan-price {
        margin: 0 !important;
        white-space: nowrap;
    }

    .subscription-plan-price-meta {
        justify-content: flex-end;
    }

    .subscription-plan-desc {
        grid-column: 1 / -1;
        margin-top: 6px;
    }

    .subscription-card-number {
        font-size: clamp(22px, 6.2vw, 28px) !important;
        letter-spacing: 0.7px !important;
    }

    .subscription-actions .main {
        flex: 1 1 100% !important;
    }
}

/* ===== PREMIUM ACTIVATION MODAL ===== */
.subscription-panel .premium-key-input {
    width: 100%;
    min-height: 48px;
    padding: 13px 14px;
    border-radius: 15px;
    border: 1px solid rgba(148, 163, 184, 0.42);
    background: #ffffff;
    color: #111827;
    font-size: 14px;
    font-weight: 700;
    outline: none;
    box-sizing: border-box;
    margin: 8px 0 10px;
}

.subscription-panel .premium-key-input:focus {
    border-color: rgba(79, 70, 229, 0.48);
    box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.12);
}

.subscription-panel .premium-note {
    margin: 8px 0 10px;
    padding: 9px 11px;
    border-radius: 14px;
    background: rgba(79, 70, 229, 0.07);
    color: #4b5563;
    font-size: 13px;
    line-height: 1.42;
    text-align: left;
}

.subscription-panel .premium-note.error {
    background: rgba(239, 68, 68, 0.09);
    color: #b91c1c;
}

.subscription-panel .premium-note.success {
    background: rgba(34, 197, 94, 0.10);
    color: #166534;
}

body.dark-theme .subscription-panel .premium-key-input {
    background: rgba(15, 23, 42, 0.78);
    border-color: rgba(148, 163, 184, 0.30);
    color: #f8fafc;
}

body.dark-theme .subscription-panel .premium-note {
    background: rgba(129, 140, 248, 0.14);
    color: #cbd5e1;
}

body.dark-theme .subscription-panel .premium-note.error {
    background: rgba(239, 68, 68, 0.14);
    color: #fecaca;
}

body.dark-theme .subscription-panel .premium-note.success {
    background: rgba(34, 197, 94, 0.14);
    color: #bbf7d0;
}

#quiz-user-name-badge.temporary-user .quiz-user-name-badge-action,
#quiz-user-name-badge.temporary-user .quiz-user-name-badge-sticker-panel,
#quiz-user-name-badge .quiz-user-name-badge-action.hidden {
    display: none !important;
}

#quiz-user-name-badge.premium-user .quiz-user-name-badge-subtitle {
    color: #7c3aed;
    font-weight: 700;
}

body.dark-theme #quiz-user-name-badge.premium-user .quiz-user-name-badge-subtitle {
    color: #c4b5fd;
}

body.dark-theme .premium-incognito-toggle.is-active {
    background: linear-gradient(135deg, #0f172a 0%, #155e75 100%) !important;
    color: #ecfeff !important;
}



/* ===== ANTI COPY (ТЕСТЫ / ИЗУЧИТЬ ТЕСТЫ / ИСТОРИЯ / ИЗБРАННОЕ) ===== */
.quiz-test-page .card,
.quiz-test-page .card *,
#question,
#question *,
#options,
#options *,
#study-list,
#study-list *,
.study-list,
.study-list *,
#favorites-list,
#favorites-list *,
#history-list,
#history-list *,
.history-details,
.history-details *,
.answers-list,
.answers-list *,
.answer-card,
.answer-card *,
.answer-question,
.answer-question *,
.answer-line,
.answer-line * {
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
}



.theme-helper-note {
    margin-top: 10px;
    padding: 10px 12px;
    border-radius: 14px;
    font-size: 12px;
    line-height: 1.5;
    color: #4b5563;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.12);
}

.theme-helper-note.hidden {
    display: none;
}

.retention-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 8px auto 10px;
    width: min(92vw, 420px);
}

.main-retention-strip {
    position: relative;
    z-index: 4;
    margin-top: 4px;
    margin-bottom: 12px;
    justify-content: center;
}

.retention-pill {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 5px;
    min-height: 30px;
    padding: 5px 10px;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.12);
    color: #312e81;
    text-align: center;
    white-space: nowrap;
}

.retention-pill span {
    font-size: 13px;
    line-height: 1;
}

.retention-pill b {
    font-size: 13px;
    line-height: 1;
}

.retention-pill small {
    font-size: 9px;
    opacity: 0.82;
}

.section-progress-card {
    margin-top: 8px;
}

.achievements-panel {
    width: min(1080px, 100%);
}

.achievements-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.achievements-summary-card {
    background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 55%, #818cf8 100%);
    border: 1px solid rgba(129, 140, 248, 0.35);
    border-radius: 22px;
    padding: 18px;
    color: #ffffff;
    box-shadow: 0 18px 40px rgba(67, 56, 202, 0.22);
}

.achievements-summary-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}

.achievements-summary-label {
    font-size: 13px;
    font-weight: 700;
    opacity: 0.9;
    margin-bottom: 6px;
}

.achievements-summary-value {
    font-size: clamp(26px, 4vw, 38px);
    line-height: 1.05;
    font-weight: 900;
}

.achievements-summary-percent {
    font-size: 24px;
    font-weight: 900;
    white-space: nowrap;
}

.achievements-progress-track {
    margin-top: 12px;
    background: rgba(255, 255, 255, 0.18);
}

.achievements-progress-track .section-progress-fill {
    background: linear-gradient(90deg, #fff 0%, #e9d5ff 100%);
}

.achievements-summary-note {
    margin-top: 10px;
    font-size: 13px;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.92);
}

.achievements-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
}


.section-progress-track {
    width: 100%;
    height: 10px;
    border-radius: 999px;
    overflow: hidden;
    background: rgba(148, 163, 184, 0.22);
    position: relative;
}

.section-progress-fill {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #6d5cff, #8b5cf6);
    box-shadow: 0 6px 16px rgba(109, 92, 255, 0.25);
}

.achievement-inline-track {
    margin-top: 8px;
    height: 8px;
    background: rgba(99, 102, 241, 0.12);
}

.achievement-card-progress-meta {
    margin-top: 8px;
    font-size: 12px;
    line-height: 1.45;
    color: #5b6475;
    font-weight: 700;
}

.achievement-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px;
    border-radius: 18px;
    border: 1px solid rgba(99, 102, 241, 0.12);
    background: rgba(99, 102, 241, 0.05);
}

.achievement-card.unlocked {
    background: linear-gradient(180deg, rgba(236, 253, 245, 0.95), rgba(220, 252, 231, 0.95));
    border-color: rgba(34, 197, 94, 0.25);
}

.achievement-card.locked {
    opacity: 0.88;
}

.achievement-card-icon {
    width: 42px;
    height: 42px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    background: rgba(99, 102, 241, 0.14);
    flex: 0 0 42px;
}

.achievement-card-body {
    min-width: 0;
    flex: 1;
}

.achievement-card-title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
}

.achievement-card-title {
    font-size: 15px;
    font-weight: 800;
    line-height: 1.3;
    color: #111827;
}

.achievement-card-state {
    border-radius: 999px;
    padding: 4px 9px;
    font-size: 11px;
    font-weight: 800;
    white-space: nowrap;
    background: rgba(99, 102, 241, 0.12);
    color: #4338ca;
}

.achievement-card.unlocked .achievement-card-state {
    background: rgba(34, 197, 94, 0.16);
    color: #166534;
}

.achievement-card-desc {
    margin-top: 6px;
    font-size: 13px;
    line-height: 1.5;
    color: #4b5563;
}

.section-progress-head,
.result-progress-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 7px;
    font-size: 12px;
    font-weight: 700;
    color: #4b5563;
}

.section-progress-percent {
    color: #4338ca;
    font-weight: 800;
}

.section-progress-bar {
    width: 100%;
    height: 10px;
    border-radius: 999px;
    overflow: hidden;
    background: rgba(148, 163, 184, 0.22);
    position: relative;
}

.section-progress-bar.large {
    height: 12px;
}

.section-progress-bar span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #6d5cff, #8b5cf6);
    box-shadow: 0 6px 16px rgba(109, 92, 255, 0.25);
}

.section-progress-meta,
.result-progress-meta {
    margin-top: 7px;
    font-size: 12px;
    line-height: 1.45;
    color: #6b7280;
}

.result-shell {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.result-hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
}

.result-title {
    font-size: 24px;
    font-weight: 900;
    color: #111827;
}

.result-subtitle {
    margin-top: 6px;
    font-size: 13px;
    line-height: 1.55;
    color: #6b7280;
}

.result-score-circle {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: linear-gradient(135deg, #6d5cff, #8b5cf6);
    color: #fff;
    font-size: 24px;
    font-weight: 900;
    box-shadow: 0 18px 35px rgba(109, 92, 255, 0.28);
}

.result-status-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.result-status-chip {
    padding: 8px 11px;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.09);
    color: #312e81;
    font-size: 12px;
    font-weight: 800;
}

.result-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
}

.result-metric {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    padding: 12px;
    border-radius: 16px;
    background: #f8fafc;
    border: 1px solid #e5e7eb;
}

.result-metric span {
    font-size: 18px;
    line-height: 1;
}

.result-metric b {
    display: block;
    color: #111827;
    font-size: 15px;
    font-weight: 900;
}

.result-metric small {
    display: block;
    margin-top: 3px;
    font-size: 11px;
    line-height: 1.45;
    color: #6b7280;
}

.result-progress-block,
.result-achievements {
    padding: 14px;
    border-radius: 18px;
    background: #f8fafc;
    border: 1px solid #e5e7eb;
}

.result-note {
    padding: 12px 14px;
    border-radius: 16px;
    background: rgba(99, 102, 241, 0.07);
    color: #374151;
    border: 1px solid rgba(99, 102, 241, 0.12);
    line-height: 1.5;
    font-size: 13px;
}

.result-achievements-title {
    font-size: 14px;
    font-weight: 900;
    color: #111827;
    margin-bottom: 10px;
}

.result-achievements-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.result-achievement-chip {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    padding: 10px 12px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(99, 102, 241, 0.12);
}

.result-achievement-chip span {
    font-size: 18px;
    line-height: 1;
}

.result-achievement-chip b {
    display: block;
    font-size: 13px;
    color: #111827;
}

.result-achievement-chip small {
    display: block;
    margin-top: 3px;
    color: #6b7280;
    font-size: 11px;
    line-height: 1.45;
}

.result-actions-stack {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

@media (max-width: 640px) {
    .result-grid,
    .achievements-grid {
        grid-template-columns: 1fr;
    }

    .retention-strip {
        gap: 6px;
        margin: 6px auto 8px;
    }

    .retention-pill {
        min-height: 28px;
        padding: 4px 8px;
        border-radius: 999px;
    }

    .retention-pill span {
        font-size: 12px;
    }

    .retention-pill b {
        font-size: 13px;
    }

    .retention-pill small {
        font-size: 9px;
    }

    .achievements-summary-card {
        padding: 15px;
    }

    .achievements-summary-percent {
        font-size: 20px;
    }

    .achievement-card {
        padding: 12px;
    }

    .result-hero {
        align-items: flex-start;
        flex-direction: column;
    }

    .result-score-circle {
        width: 78px;
        height: 78px;
        font-size: 22px;
    }
}

body.dark-theme .theme-helper-note,
body.dark-theme .retention-pill,
body.dark-theme .result-note,
body.dark-theme .result-status-chip {
    background: rgba(49, 46, 129, 0.35) !important;
    border-color: rgba(129, 140, 248, 0.22) !important;
    color: #e5e7eb !important;
}

body.dark-theme .section-progress-meta,
body.dark-theme .section-progress-head,
body.dark-theme .result-progress-meta,
body.dark-theme .result-subtitle,
body.dark-theme .result-metric small,
body.dark-theme .result-achievement-chip small {
    color: #cbd5e1 !important;
}

body.dark-theme .result-title,
body.dark-theme .result-achievements-title,
body.dark-theme .result-metric b,
body.dark-theme .result-achievement-chip b {
    color: #f8fafc !important;
}

body.dark-theme .result-metric,
body.dark-theme .result-progress-block,
body.dark-theme .result-achievements,
body.dark-theme .result-achievement-chip,
body.dark-theme .achievement-card,
body.dark-theme .achievement-card-icon {
    background: linear-gradient(180deg, rgba(10, 18, 38, 0.96), rgba(15, 23, 42, 0.99)) !important;
    border-color: rgba(129, 140, 248, 0.2) !important;
}

body.dark-theme .achievement-card.unlocked {
    background: linear-gradient(180deg, rgba(6, 78, 59, 0.92), rgba(6, 95, 70, 0.92)) !important;
    border-color: rgba(74, 222, 128, 0.22) !important;
}

body.dark-theme .achievement-card-title,
body.dark-theme .achievement-card-state,
body.dark-theme .achievement-card-desc,
body.dark-theme .achievements-summary-note,
body.dark-theme .achievements-summary-label,
body.dark-theme .achievements-summary-value,
body.dark-theme .achievements-summary-percent {
    color: #f8fafc !important;
}

body.dark-theme .achievement-card.locked .achievement-card-desc {
    color: #cbd5e1 !important;
}

body.dark-theme .achievement-card.locked .achievement-card-state {
    background: rgba(129, 140, 248, 0.16) !important;
    color: #e0e7ff !important;
}

body.dark-theme .achievement-card.unlocked .achievement-card-state {
    background: rgba(74, 222, 128, 0.16) !important;
    color: #dcfce7 !important;
}

.section-progress-head {
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:8px;
    margin-bottom:6px;
}
.section-progress-label, .section-progress-percent {
    font-size:12px;
    font-weight:800;
}
.section-progress-bar {
    height:10px;
    border-radius:999px;
    background:rgba(148,163,184,.24);
    overflow:hidden;
}
.section-progress-bar span {
    display:block;
    height:100%;
    border-radius:inherit;
    background:linear-gradient(135deg,#6366f1 0%, #8b5cf6 100%);
}
.section-progress-meta {
    margin-top:6px;
    font-size:12px;
    color:#6b7280;
}
body.dark-theme .section-progress-meta {
    color:#94a3b8;
}

@media (max-width: 640px) {
  .app-drawer { width:min(340px, calc(100vw - 20px)); }
  .app-drawer-header { margin-bottom: 12px; }
  .app-drawer-title { font-size: 19px; }
  .app-drawer-subtitle { font-size: 12px; }
  .app-menu-list { gap: 8px; }
  .app-menu-item { padding: 10px 10px; }
  .app-menu-item-label { font-size: 13px; }
  .app-menu-item-badge { padding: 3px 7px; font-size: 10px; }
  .app-menu-children { gap: 6px; padding: 0 8px 8px; }
  .app-menu-subitem { padding: 9px 10px; border-radius: 12px; }
  .app-menu-subitem-label { font-size: 13px; }
  .section-progress-head { margin-bottom: 4px; }
  .section-progress-label, .section-progress-percent, .section-progress-meta { font-size: 11px; }
  .section-progress-bar { height: 8px; }
}

body.dark-theme .achievement-card-progress-meta {
    color: #dbe4f0 !important;
}




/* ===== COMPACT MENU + DIRECT ACHIEVEMENTS FIX ===== */
.app-drawer {
  width: min(328px, calc(100vw - 18px));
  padding: 10px 10px 12px;
}
.app-drawer-header {
  margin-bottom: 10px;
}
.app-drawer-title {
  font-size: 19px;
}
.app-drawer-subtitle {
  font-size: 12px;
  margin-top: 2px;
}
.app-menu-list {
  gap: 6px;
}
.app-menu-card,
.app-menu-item-standalone {
  border-radius: 14px;
}
.app-menu-item {
  padding: 10px 10px;
}
.app-menu-item-label {
  font-size: 13px;
}
.app-menu-item-badge {
  padding: 2px 7px;
  font-size: 10px;
}
.app-menu-children {
  gap: 6px;
  padding: 0 8px 8px;
}
.app-menu-subitem {
  border-radius: 12px;
  padding: 8px 10px;
}
.app-menu-subitem-label {
  font-size: 13px;
}
.section-progress-card {
  margin-top: 6px;
}
.section-progress-head,
.result-progress-head {
  margin-bottom: 5px;
  font-size: 11px;
}
.section-progress-track,
.section-progress-bar {
  height: 8px;
}
.section-progress-meta,
.result-progress-meta {
  margin-top: 5px;
  font-size: 11px;
}
.achievements-modal-direct-overlay {
  align-items: center;
  justify-content: center;
  padding: 12px;
}
.achievements-panel-direct {
  width: min(1080px, 100%);
  max-height: 88vh;
}
@media (max-width: 640px) {
  .app-drawer {
    width: min(312px, calc(100vw - 14px));
    padding: 9px 9px 10px;
  }
  .app-drawer-actions {
    gap: 8px;
  }
  .app-drawer-close,
  .app-drawer-icon-button {
    width: 40px;
    height: 40px;
    border-radius: 12px;
  }
  .achievements-panel-direct {
    border-radius: 20px;
    padding: 14px;
  }
  .achievements-grid {
    grid-template-columns: 1fr;
    gap: 10px;
  }
  .achievement-card {
    border-radius: 16px;
  }
}


/* Reliable achievements modal compact layout */
.achievements-panel {
  width: min(820px, 100%);
  max-height: 84vh;
}
.achievements-content {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.achievements-summary-card {
  padding: 10px 12px;
  border-radius: 16px;
}
.achievements-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 8px;
}
.achievement-card {
  border-radius: 16px;
  padding: 10px;
}
.achievement-card-icon {
  font-size: 22px;
}
.achievement-card-title {
  font-size: 14px;
}
.achievement-card-desc,
.achievement-card-progress-meta,
.achievement-card-state,
.achievements-summary-note,
.achievements-summary-label,
.achievements-summary-value,
.achievements-summary-percent {
  font-size: 12px;
}
@media (min-width: 700px) {
  .achievements-grid {
    grid-template-columns: 1fr 1fr;
  }
}
@media (max-width: 640px) {
  .achievements-panel {
    width: min(100%, 100%);
    max-height: 88vh;
    padding: 12px;
    border-radius: 18px;
  }
  .history-panel-header {
    gap: 8px;
  }
  .history-title {
    font-size: 18px;
  }
  .history-subtitle {
    font-size: 11px;
  }
}

/* ===== RESULT SCREEN COMPACT FIX ===== */
.quiz-test-page .card .result-shell {
    gap: 10px;
    text-align: left;
}

.quiz-test-page .card .result-hero {
    padding-bottom: 2px;
    align-items: center;
}

.quiz-test-page .card .result-title {
    font-size: 22px;
    line-height: 1.12;
}

.quiz-test-page .card .result-subtitle {
    margin-top: 4px;
    font-size: 12px;
    line-height: 1.35;
}

.quiz-test-page .card .result-score-circle {
    width: 68px;
    height: 68px;
    font-size: 20px;
    box-shadow: 0 12px 26px rgba(109, 92, 255, 0.22);
}

.quiz-test-page .card .result-status-row {
    gap: 6px;
}

.quiz-test-page .card .result-status-chip {
    padding: 6px 9px;
    font-size: 11px;
}

.quiz-test-page .card .result-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
}

.quiz-test-page .card .result-metric {
    padding: 9px;
    border-radius: 14px;
    gap: 7px;
}

.quiz-test-page .card .result-metric span {
    font-size: 16px;
}

.quiz-test-page .card .result-metric b {
    font-size: 13px;
    line-height: 1.2;
    word-break: break-word;
}

.quiz-test-page .card .result-metric small {
    font-size: 10px;
    line-height: 1.25;
}

.quiz-test-page .card .result-progress-block,
.quiz-test-page .card .result-achievements,
.quiz-test-page .card .result-note {
    padding: 10px 11px;
    border-radius: 14px;
}

.quiz-test-page .card .result-actions-stack {
    gap: 7px;
}

.quiz-test-page .card .result-actions-stack .main {
    min-height: 42px;
    padding: 10px 12px;
    border-radius: 14px;
    font-size: 14px;
}

@media (max-width: 640px) {
    .quiz-test-page .card .result-hero {
        flex-direction: row;
        align-items: center;
    }

    .quiz-test-page .card .result-score-circle {
        width: 60px;
        height: 60px;
        font-size: 18px;
    }

    .quiz-test-page .card .result-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
}

@media (max-width: 380px) {
    .quiz-test-page .card .result-title {
        font-size: 20px;
    }

    .quiz-test-page .card .result-score-circle {
        width: 56px;
        height: 56px;
        font-size: 17px;
    }
}

/* ===== BURGER MENU LIVE INFO: WEATHER + USD RATE ===== */
.app-menu-live-info {
    margin-top: 14px;
    border: 1px solid rgba(99, 102, 241, 0.22);
    border-radius: 18px;
    background: linear-gradient(145deg, #f8fafc 0%, #eef2ff 100%);
    box-shadow: 0 12px 26px rgba(79, 70, 229, 0.10);
    padding: 13px 13px 12px;
    color: #111827;
}

.app-menu-live-info-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
}

.app-menu-live-info-title {
    font-size: 14px;
    font-weight: 900;
    color: #312e81;
    line-height: 1.15;
}

.app-menu-live-info-subtitle {
    margin-top: 2px;
    font-size: 11px;
    font-weight: 700;
    color: #6b7280;
}

.app-menu-live-info-refresh {
    width: 34px;
    height: 34px;
    border: 1px solid rgba(99, 102, 241, 0.22);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.84);
    color: #4f46e5;
    font-size: 18px;
    font-weight: 900;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 8px 18px rgba(79, 70, 229, 0.10);
}

.app-menu-live-info-refresh:disabled {
    opacity: 0.55;
    cursor: wait;
}

.app-menu-live-info.is-loading .app-menu-live-info-refresh {
    animation: appMenuLiveSpin 0.85s linear infinite;
}

@keyframes appMenuLiveSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.app-menu-live-info-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 9px 0;
    border-top: 1px solid rgba(99, 102, 241, 0.13);
}

.app-menu-live-info-row span {
    color: #64748b;
    font-size: 12px;
    font-weight: 800;
}

.app-menu-live-info-row strong {
    color: #111827;
    font-size: 13px;
    font-weight: 900;
    text-align: right;
    white-space: nowrap;
}

.app-menu-live-info-updated {
    min-height: 14px;
    margin-top: 2px;
    color: #818cf8;
    font-size: 10.5px;
    font-weight: 800;
    line-height: 1.25;
}

.app-menu-live-info.has-error .app-menu-live-info-updated {
    color: #b45309;
}

body.dark-theme .app-menu-live-info {
    background: linear-gradient(145deg, rgba(30, 41, 59, 0.92), rgba(49, 46, 129, 0.62)) !important;
    border-color: rgba(129, 140, 248, 0.28) !important;
    color: #f8fafc !important;
    box-shadow: 0 14px 28px rgba(2, 6, 23, 0.42) !important;
}

body.dark-theme .app-menu-live-info-title,
body.dark-theme .app-menu-live-info-row strong {
    color: #f8fafc !important;
}

body.dark-theme .app-menu-live-info-subtitle,
body.dark-theme .app-menu-live-info-row span {
    color: #cbd5e1 !important;
}

body.dark-theme .app-menu-live-info-refresh {
    background: rgba(15, 23, 42, 0.82) !important;
    color: #c7d2fe !important;
    border-color: rgba(129, 140, 248, 0.30) !important;
}

body.dark-theme .app-menu-live-info-row {
    border-top-color: rgba(129, 140, 248, 0.18) !important;
}

body.dark-theme .app-menu-live-info-updated {
    color: #c4b5fd !important;
}

body.dark-theme .app-menu-live-info.has-error .app-menu-live-info-updated {
    color: #fcd34d !important;
}

@media (max-width: 640px) {
    .app-menu-live-info {
        margin-top: 12px;
        padding: 12px;
        border-radius: 16px;
    }

    .app-menu-live-info-row strong {
        font-size: 12.5px;
    }
}


body.dark-theme .news-date {
    background: rgba(79, 70, 229, 0.28) !important;
    color: #c4b5fd !important;
}

body.dark-theme .news-type {
    background: rgba(30, 41, 59, 0.92) !important;
    color: #e5e7eb !important;
}


.subscription-limit-info,
.limit-comparison-note {
    margin: 12px 0;
    padding: 11px 13px;
    border-radius: 16px;
    background: rgba(14, 165, 233, 0.08);
    border: 1px solid rgba(14, 165, 233, 0.20);
    color: #075985;
    font-size: 13px;
    font-weight: 750;
    line-height: 1.38;
    text-align: left;
}

.limit-comparison-note {
    margin-top: 12px;
    margin-bottom: 2px;
}

body.dark-theme .subscription-limit-info,
body.dark-theme .limit-comparison-note {
    background: rgba(14, 165, 233, 0.12);
    border-color: rgba(56, 189, 248, 0.22);
    color: #bae6fd;
}

/* ===== TEMPORARY DAILY LIMIT / PREMIUM COMPARISON ===== */
.temporary-limit-overlay .temporary-limit-panel {
    width: min(92vw, 460px);
}

.limit-plan-switch {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    padding: 5px;
    margin: 12px 0 14px;
    border-radius: 18px;
    background: rgba(15, 23, 42, 0.06);
    border: 1px solid rgba(148, 163, 184, 0.22);
}

.limit-plan-switch button {
    min-height: 44px;
    border: 0;
    border-radius: 14px;
    background: transparent;
    color: #64748b;
    font-size: 14px;
    font-weight: 850;
    cursor: pointer;
    transition: 0.18s ease;
}

.limit-plan-switch button.active {
    background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%);
    color: #ffffff;
    box-shadow: 0 12px 26px rgba(37, 99, 235, 0.22);
}

.limit-plan-panel {
    border: 1px solid rgba(14, 165, 233, 0.20);
    border-radius: 20px;
    padding: 14px;
    background: linear-gradient(180deg, rgba(240, 249, 255, 0.98), rgba(255, 255, 255, 0.98));
    box-shadow: 0 12px 26px rgba(15, 23, 42, 0.06);
    text-align: left;
}

.limit-plan-panel.hidden {
    display: none;
}

.limit-plan-title {
    margin-bottom: 10px;
    font-size: 17px;
    font-weight: 950;
    color: #0f172a;
}

.limit-plan-title.premium {
    color: #0369a1;
}

.limit-benefits-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 9px;
}

.limit-benefits-list li {
    position: relative;
    padding-left: 26px;
    color: #334155;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.35;
}

.limit-benefits-list li::before {
    content: "•";
    position: absolute;
    left: 4px;
    top: -1px;
    color: #94a3b8;
    font-size: 22px;
    line-height: 1;
}

.limit-benefits-list.premium li::before {
    content: "✓";
    left: 2px;
    top: 0;
    color: #0ea5e9;
    font-size: 16px;
    font-weight: 950;
}

.limit-actions {
    margin-top: 14px;
}

body.dark-theme .limit-plan-switch {
    background: rgba(15, 23, 42, 0.56);
    border-color: rgba(148, 163, 184, 0.18);
}

body.dark-theme .limit-plan-switch button {
    color: #cbd5e1;
}

body.dark-theme .limit-plan-switch button.active {
    color: #ffffff;
}

body.dark-theme .limit-plan-panel {
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.92), rgba(30, 41, 59, 0.92));
    border-color: rgba(56, 189, 248, 0.18);
}

body.dark-theme .limit-plan-title {
    color: #f8fafc;
}

body.dark-theme .limit-plan-title.premium {
    color: #7dd3fc;
}

body.dark-theme .limit-benefits-list li {
    color: #cbd5e1;
}
